# Security and best-practice headers for SebAid Foundation
# Applied to all routes when deployed on Netlify

/*
  # Prevent clickjacking
  X-Frame-Options: DENY
  # Prevent MIME sniffing
  X-Content-Type-Options: nosniff
  # Control referrer information
  Referrer-Policy: strict-origin-when-cross-origin
  # Restrict browser features (no geolocation, camera, etc. by default)
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  # Content Security Policy (allow self, fonts, images from trusted CDNs)
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self'; frame-src https://www.youtube.com https://www.youtube-nocookie.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  # Enforce HTTPS (handled by Netlify; optional strict transport)
  X-XSS-Protection: 1; mode=block
